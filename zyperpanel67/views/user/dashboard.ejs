<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Dashboard - <%= settings.panelName %></title>

    <link rel="icon" href="/falcon.ico" />

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        color: white;
      }

      .video-bg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -2;
      }

      .overlay {
        position: fixed;
        inset: 0;
        background: linear-gradient(
          180deg,
          rgba(5, 10, 20, 0.45),
          rgba(0, 0, 0, 0.65)
        );
        z-index: -1;
      }

      .glass {
        background: rgba(20, 25, 40, 0.25);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
      }

      .wrapper {
        display: flex;
        min-height: 100vh;
      }

      .sidebar {
        width: 260px;
        padding: 20px;
        display: flex;
        flex-direction: column;
      }

      .logo {
        font-size: 22px;
        font-weight: bold;
        padding: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }

      .menu {
        margin-top: 20px;
      }

      .menu a,
      .logout-btn {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 13px 16px;
        margin-bottom: 10px;
        border-radius: 12px;
        text-decoration: none;
        color: #ddd;
        transition: 0.3s;
      }

      .menu a:hover,
      .logout-btn:hover {
        background: rgba(255, 255, 255, 0.15);
        transform: translateX(5px);
      }

      .icon {
        width: 22px;
        height: 22px;
        display: inline-block;
        position: relative;
      }

      /* DASHBOARD */
      .home {
        width: 22px;
        height: 18px;
        background: #a78bfa;
        border-radius: 6px;
        margin-top: 5px;
      }

      .home:before {
        content: "";
        position: absolute;
        width: 15px;
        height: 15px;
        background: #a78bfa;
        transform: rotate(45deg);
        top: -8px;
        left: 3px;
      }

      .home:after {
        content: "";
        position: absolute;
        width: 7px;
        height: 10px;
        background: white;
        bottom: 0;
        left: 8px;
      }

      /* ACCOUNT */
      .user {
        border: 2px solid #60a5fa;
        border-radius: 50%;
      }

      .user:before {
        content: "";
        position: absolute;
        width: 7px;
        height: 7px;
        background: #60a5fa;
        border-radius: 50%;
        top: 3px;
        left: 5px;
      }

      .user:after {
        content: "";
        position: absolute;
        width: 12px;
        height: 7px;
        background: #60a5fa;
        border-radius: 10px;
        bottom: 3px;
        left: 3px;
      }

      /* ADMIN */
      .gear {
        border: 3px solid #c4b5fd;
        border-radius: 50%;
      }

      .gear:before {
        content: "";
        position: absolute;
        width: 8px;
        height: 8px;
        background: #c4b5fd;
        border-radius: 50%;
        top: 4px;
        left: 4px;
      }

      /* LOGOUT */
      .logout {
        border: 2px solid #f87171;
        border-radius: 5px;
      }

      .logout:before {
        content: "";
        position: absolute;
        width: 12px;
        height: 2px;
        background: #f87171;
        right: -8px;
        top: 8px;
      }

      .logout:after {
        content: "";
        position: absolute;
        border-left: 7px solid #f87171;
        border-top: 5px solid transparent;
        border-bottom: 5px solid transparent;
        right: -15px;
        top: 4px;
      }

      .content {
        flex: 1;
        padding: 40px;
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
      }

      .server {
        padding: 20px;
        border-radius: 25px;
        background: rgba(20, 25, 40, 0.22);
        backdrop-filter: blur(22px);
        transition: 0.3s;
      }

      .server:hover {
        transform: translateY(-7px);
        box-shadow: 0 0 35px rgba(139, 92, 246, 0.45);
      }

      .mc-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        background: linear-gradient(135deg, #8b5a2b 50%, #573318 50%);
      }

      .info {
        background: rgba(255, 255, 255, 0.07);
        padding: 12px;
        border-radius: 15px;
        margin-top: 12px;
      }

      .button {
        display: block;
        margin-top: 15px;
        padding: 12px;
        text-align: center;
        border-radius: 12px;
        background: rgba(139, 92, 246, 0.35);
        color: white;
        text-decoration: none;
      }
    </style>
  </head>

  <body>
    <video class="video-bg" autoplay muted loop playsinline>
      <source src="/wallpaper.mp4" type="video/mp4" />
    </video>

    <div class="overlay"></div>

    <div class="wrapper">
      <aside class="sidebar glass">
        <div class="logo"><%= settings.panelName %></div>

        <div class="menu">
          <a href="/dashboard">
            <span class="icon home"></span>
            Dashboard
          </a>

          <a href="/account">
            <span class="icon user"></span>
            Account
          </a>

          <% if (typeof user !== 'undefined' && user && user.isAdmin) { %>
          <a href="/admin/overview">
            <span class="icon gear"></span>
            Admin Panel
          </a>
          <% } %>
        </div>

        <div style="margin-top: auto">
          <a href="/auth/logout" class="logout-btn">
            <span class="icon logout"></span>
            Logout
          </a>
        </div>
      </aside>

      <main class="content">
        <h1>My Servers</h1>

        <div class="cards">
          <% if (typeof servers !== 'undefined' && servers && servers.length >
          0) { %> <% servers.forEach(server => { let primary =
          (server.allocations || []).find(a => a.isPrimary); %>

          <div class="server glass">
            <div style="display: flex; gap: 15px; align-items: center">
              <div class="mc-icon"></div>

              <div>
                <h2><%= server.name %></h2>
                <p><%= server.status %></p>
              </div>
            </div>

            <div class="info">
              <b>IP</b>
              <br />
              <% if (primary) { %> <%= (primary.allocation?.alias ||
              primary.allocation?.ipAddress || primary.alias ||
              primary.ipAddress) %>:<%= primary.port %> <% } else { %> No
              allocation <% } %>
            </div>

            <div class="info">
              Version: <%= server.version %>
              <br />
              RAM: <%= server.memory %> MB
              <br />
              CPU: <%= server.cpu %>%
            </div>

            <a class="button" href="/server/<%= server.id %>">
              Manage Server
            </a>
          </div>

          <% }) %> <% } else { %>
          <div class="col-span-full text-center py-12 glass rounded-2xl">
            <p class="text-gray-400">
              No servers found assigned to this account.
            </p>
          </div>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>
