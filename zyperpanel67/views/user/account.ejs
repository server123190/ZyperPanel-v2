<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">


<title>
Account - <%= settings.panelName %>
</title>


<link rel="icon" href="/falcon.ico">



<style>


*{

box-sizing:border-box;

}


body{


margin:0;


font-family:Arial,sans-serif;


color:white;


min-height:100vh;


}





.video-bg{


position:fixed;


inset:0;


width:100%;


height:100%;


object-fit:cover;


z-index:-2;


}





.overlay{


position:fixed;


inset:0;


background:

rgba(0,0,0,.55);


z-index:-1;


}







.container{


max-width:750px;


margin:40px auto;


padding:20px;


}






.glass{


background:

rgba(20,25,40,.35);


backdrop-filter:

blur(20px);



border:

1px solid rgba(255,255,255,.15);



border-radius:25px;



padding:25px;



margin-bottom:25px;


}






h1{


font-size:34px;


}





.section-title{


display:flex;


align-items:center;


gap:15px;


}





.section-icon{


width:45px;


height:45px;


border-radius:14px;


display:flex;


align-items:center;


justify-content:center;


background:

rgba(139,92,246,.25);


position:relative;


}







/* USER ICON */


.profile-icon:before{


content:"";


width:12px;


height:12px;


background:#c4b5fd;


border-radius:50%;


position:absolute;


top:8px;


}



.profile-icon:after{


content:"";


width:24px;


height:13px;


background:#c4b5fd;


border-radius:15px 15px 5px 5px;


position:absolute;


bottom:8px;


}








/* EMAIL ICON */


.email-icon{


border:

3px solid #60a5fa;


}



.email-icon:before{


content:"";


position:absolute;


width:18px;


height:12px;


border-bottom:

3px solid #60a5fa;


transform:

rotate(45deg);


top:10px;


left:10px;


}







/* PASSWORD ICON */


.lock-icon{


border:

3px solid #f87171;


border-radius:8px;


}



.lock-icon:before{


content:"";


position:absolute;


width:14px;


height:14px;


border:

3px solid #f87171;


border-bottom:0;


border-radius:10px 10px 0 0;


top:-12px;


left:11px;


}



.lock-icon:after{


content:"";


position:absolute;


width:6px;


height:12px;


background:#f87171;


left:17px;


top:14px;


}








.description{


color:#aaa;


margin-bottom:20px;


}





label{


display:block;


color:#ddd;


margin-bottom:8px;


}





input{


width:100%;


padding:14px;


border-radius:12px;



background:

rgba(255,255,255,.08);



border:

1px solid rgba(255,255,255,.15);



color:white;


outline:none;


margin-bottom:18px;


}





input:focus{


border-color:#8b5cf6;


}






button{


width:100%;


padding:14px;


border:0;


border-radius:14px;


background:

rgba(139,92,246,.6);


color:white;


font-size:16px;


cursor:pointer;


transition:.3s;


}



button:hover{


background:

rgba(139,92,246,.85);


}







.back{


color:#aaa;


text-decoration:none;


}




</style>

</head>



<body>




<video class="video-bg"

autoplay

muted

loop

playsinline>


<source src="/wallpaper.mp4" type="video/mp4">


</video>



<div class="overlay"></div>






<div class="container">





<h1>

Account Settings

</h1>







<form method="POST" action="/account/update">






<div class="glass">


<div class="section-title">


<div class="section-icon profile-icon"></div>


<h2>

Profile

</h2>


</div>



<p class="description">

Update your username.

</p>




<label>

Username

</label>


<input

name="username"

value="<%=user.username%>"

>



<button>

Save Username

</button>


</div>









<div class="glass">


<div class="section-title">


<div class="section-icon email-icon"></div>


<h2>

Email

</h2>


</div>




<p class="description">

Change your account email.

</p>




<label>

Email

</label>


<input

type="email"

name="email"

value="<%=user.email%>"

>




<button>

Save Email

</button>



</div>









<div class="glass">


<div class="section-title">


<div class="section-icon lock-icon"></div>


<h2>

Security

</h2>


</div>




<p class="description">

Old password is required before changing password.

</p>




<label>

Old Password

</label>


<input

type="password"

name="oldPassword"

placeholder="Current password"

>





<label>

New Password

</label>


<input

type="password"

name="newPassword"

placeholder="New password"

>





<button>

Change Password

</button>



</div>






</form>






<a class="back" href="/dashboard">

← Back to Dashboard

</a>





</div>




</body>

</html>