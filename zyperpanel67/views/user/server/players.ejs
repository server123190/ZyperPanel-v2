<% currentPage = typeof currentPage !== 'undefined' ? currentPage : 'players';
%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Players - <%= server.name %></title>
    <link rel="icon" href="/falcon.ico" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        color: white;
        background-color: #050a14;
      }

      /* BACKGROUND */
      .video-bg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -2;
      }

      .overlay {
        position: fixed;
        inset: 0;
        background: linear-gradient(
          180deg,
          rgba(5, 10, 20, 0.45),
          rgba(0, 0, 0, 0.75)
        );
        z-index: -1;
      }

      /* GLASS */
      .glass {
        background: rgba(20, 25, 40, 0.35);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
      }

      /* LAYOUT */
      .wrapper {
        display: flex;
        min-height: 100vh;
      }

      .sidebar {
        width: 270px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        position: fixed;
        height: 100vh;
        overflow-y: auto;
      }

      /* Custom scrollbar for sidebar to match aesthetic */
      .sidebar::-webkit-scrollbar {
        width: 4px;
      }
      .sidebar::-webkit-scrollbar-track {
        background: transparent;
      }
      .sidebar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 2px;
      }

      .content {
        margin-left: 270px;
        flex: 1;
        padding: 35px;
      }

      .logo {
        font-size: 22px;
        font-weight: bold;
        padding: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 10px;
      }

      /* ICONS */
      .icon {
        width: 22px;
        height: 22px;
        position: relative;
        display: inline-block;
      }

      /* home */
      .home {
        background: #a78bfa;
        width: 20px;
        height: 15px;
        border-radius: 4px;
        margin-top: 5px;
      }

      .home:before {
        content: "";
        position: absolute;
        width: 15px;
        height: 15px;
        background: #a78bfa;
        transform: rotate(45deg);
        top: -8px;
        left: 2px;
      }

      /* console */
      .console {
        border: 2px solid #60a5fa;
        border-radius: 5px;
      }

      .console:after {
        content: ">";
        position: absolute;
        left: 5px;
        top: -4px;
        color: #60a5fa;
        font-weight: bold;
      }

      /* files */
      .file {
        border: 2px solid #34d399;
        border-radius: 3px;
      }

      .file:before {
        content: "";
        position: absolute;
        width: 8px;
        height: 5px;
        background: #34d399;
        top: -5px;
        left: 3px;
      }

      /* players */
      .player {
        border: 2px solid #facc15;
        border-radius: 50%;
      }

      .player:after {
        content: "";
        position: absolute;
        width: 12px;
        height: 6px;
        background: #facc15;
        bottom: -6px;
        left: 3px;
        border-radius: 10px;
      }

      /* settings */
      .setting {
        border: 3px solid #c084fc;
        border-radius: 50%;
      }

      /* plugins */
      .plugin {
        border: 2px solid #fb923c;
        border-radius: 4px;
      }

      .plugin:before {
        content: "";
        position: absolute;
        width: 6px;
        height: 6px;
        background: #fb923c;
        border-radius: 50%;
        top: -6px;
        left: 1px;
        box-shadow: 8px 0 0 #fb923c;
      }

      /* version */
      .version {
        border: 2px solid #22d3ee;
        border-radius: 4px;
      }

      .version:after {
        content: "";
        position: absolute;
        width: 12px;
        height: 2px;
        background: #22d3ee;
        top: 6px;
        left: 3px;
        box-shadow: 0 5px 0 #22d3ee;
      }

      /* MENU */
      .menu a {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 13px;
        margin-top: 10px;
        border-radius: 12px;
        text-decoration: none;
        color: #ddd;
        transition: 0.3s;
      }

      .menu a:hover {
        background: rgba(255, 255, 255, 0.15);
        transform: translateX(5px);
      }

      .active {
        background: rgba(139, 92, 246, 0.25);
        color: #c4b5fd !important;
      }

      .topbar {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 20px;
        margin-bottom: 20px;
      }
    </style>
  </head>
  <body>
    <video class="video-bg" autoplay muted loop playsinline>
      <source src="/wallpaper.mp4" type="video/mp4" />
    </video>

    <div class="overlay"></div>

    <div class="wrapper">
      <aside class="sidebar glass">
        <div class="logo"><%= settings.panelName %></div>

        <div class="menu">
          <a
            href="/server/<%=server.id%>"
            class="<%= currentPage === 'overview' ? 'active' : '' %>"
          >
            <span class="icon home"></span>
            Overview
          </a>

          <a
            href="/server/<%=server.id%>/console"
            class="<%= currentPage === 'console' ? 'active' : '' %>"
          >
            <span class="icon console"></span>
            Console
          </a>

          <a
            href="/server/<%=server.id%>/files"
            class="<%= currentPage === 'files' ? 'active' : '' %>"
          >
            <span class="icon file"></span>
            Files
          </a>

          <a
            href="/server/<%=server.id%>/plugins"
            class="<%= currentPage === 'plugins' ? 'active' : '' %>"
          >
            <span class="icon plugin"></span>
            Plugins
          </a>

          <a
            href="/server/<%=server.id%>/versions"
            class="<%= currentPage === 'version' ? 'active' : '' %>"
          >
            <span class="icon version"></span>
            Version
          </a>

          <a
            href="/server/<%=server.id%>/players"
            class="<%= currentPage === 'players' ? 'active' : '' %>"
          >
            <span class="icon player"></span>
            Players
          </a>

          <a
            href="/server/<%=server.id%>/settings"
            class="<%= currentPage === 'settings' ? 'active' : '' %>"
          >
            <span class="icon setting"></span>
            Settings
          </a>
        </div>

        <div style="margin-top: auto">
          <a
            href="/dashboard"
            class="flex items-center gap-2 text-gray-400 hover:text-white transition-colors p-3"
          >
            ← Back Dashboard
          </a>
        </div>
      </aside>

      <main class="content">
        <!-- TOPBAR LINK -->
        <div class="topbar glass rounded-xl">
          <a
            href="/server/<%= server.id %>"
            class="text-gray-300 hover:text-white transition-colors"
          >
            <i class="fas fa-arrow-left mr-2"></i>Back to Server
          </a>
          <span class="text-xl font-bold flex-1 truncate ml-4">
            <i class="fas fa-users mr-2"></i><%= server.name %> - Players
          </span>
        </div>

        <!-- Players List Content -->
        <% if (players.length === 0) { %>
        <div class="glass rounded-xl p-12 text-center text-gray-400">
          <i class="fas fa-user-slash text-4xl mb-4 opacity-50"></i>
          <p class="text-lg">No players online</p>
        </div>
        <% } else { %>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% players.forEach(player => { %>
          <div class="glass rounded-xl p-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <img
                src="https://mc-heads.net/avatar/<%= player.username %>/32"
                class="w-8 h-8 rounded"
              />
              <div>
                <p class="font-semibold text-gray-100">
                  <%= player.username %>
                </p>
                <p class="text-xs text-gray-400 font-medium">
                  <%= player.op ? 'OP' : 'Player' %>
                </p>
              </div>
            </div>
            <div class="flex gap-2">
              <button
                class="px-3 py-1 text-sm bg-yellow-500/20 text-yellow-400 rounded hover:bg-yellow-500/30 transition-colors"
              >
                Kick
              </button>
              <button
                class="px-3 py-1 text-sm bg-red-500/20 text-red-400 rounded hover:bg-red-500/30 transition-colors"
              >
                Ban
              </button>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </main>
    </div>
  </body>
</html>
