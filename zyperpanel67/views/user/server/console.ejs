<% currentPage = typeof currentPage !== 'undefined' ? currentPage : 'console';
%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Console - <%= server.name %></title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link rel="icon" href="/falcon.ico" />

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial;
        color: white;
      }

      .video-bg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -2;
      }

      .overlay {
        position: fixed;
        inset: 0;

        background: linear-gradient(
          180deg,
          rgba(0, 0, 0, 0.55),
          rgba(0, 0, 0, 0.8)
        );

        z-index: -1;
      }

      .glass {
        background: rgba(20, 25, 40, 0.35);

        backdrop-filter: blur(20px);

        -webkit-backdrop-filter: blur(20px);

        border: 1px solid rgba(255, 255, 255, 0.12);

        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
      }

      .wrapper {
        display: flex;

        min-height: 100vh;
      }

      .sidebar {
        width: 270px;
        padding: 20px;

        display: flex;
        flex-direction: column;

        position: fixed;

        height: 100vh;

        overflow-y: auto;
      }

      .content {
        margin-left: 270px;

        flex: 1;

        padding: 30px;
      }

      .logo {
        font-size: 22px;

        font-weight: bold;

        padding: 20px;

        border-bottom: 1px solid rgba(255, 255, 255, 0.1);

        margin-bottom: 10px;
      }

      .icon {
        width: 22px;
        height: 22px;

        display: inline-block;

        position: relative;
      }

      /* home */

      .home {
        background: #a78bfa;

        height: 15px;
        width: 20px;

        border-radius: 4px;

        margin-top: 5px;
      }

      .home:before {
        content: "";

        position: absolute;

        width: 15px;

        height: 15px;

        background: #a78bfa;

        transform: rotate(45deg);

        top: -8px;

        left: 2px;
      }

      /* console */

      .console {
        border: 2px solid #60a5fa;

        border-radius: 5px;
      }

      .console:after {
        content: ">";

        position: absolute;

        left: 5px;

        top: -4px;

        color: #60a5fa;

        font-weight: bold;
      }

      /* files */

      .file {
        border: 2px solid #34d399;

        border-radius: 3px;
      }

      .file:before {
        content: "";

        position: absolute;

        width: 8px;

        height: 5px;

        background: #34d399;

        top: -5px;

        left: 3px;
      }

      /* players */

      .player {
        border: 2px solid #facc15;

        border-radius: 50%;
      }

      .player:after {
        content: "";

        position: absolute;

        width: 12px;

        height: 6px;

        background: #facc15;

        bottom: -6px;

        left: 3px;

        border-radius: 10px;
      }

      /* settings */

      .setting {
        border: 3px solid #c084fc;

        border-radius: 50%;
      }

      /* plugins */

      .plugin {
        border: 2px solid #fb923c;

        border-radius: 4px;
      }

      .plugin:before {
        content: "";

        position: absolute;

        width: 6px;

        height: 6px;

        background: #fb923c;

        border-radius: 50%;

        top: -6px;

        left: 1px;

        box-shadow: 8px 0 0 #fb923c;
      }

      /* version */

      .version {
        border: 2px solid #22d3ee;

        border-radius: 4px;
      }

      .version:after {
        content: "";

        position: absolute;

        width: 12px;

        height: 2px;

        background: #22d3ee;

        top: 6px;

        left: 3px;

        box-shadow: 0 5px 0 #22d3ee;
      }

      /* MENU */

      .menu a {
        display: flex;

        align-items: center;

        gap: 15px;

        padding: 13px;

        margin-top: 10px;

        border-radius: 12px;

        text-decoration: none;

        color: #ddd;

        transition: 0.3s;
      }

      .menu a:hover {
        background: rgba(255, 255, 255, 0.15);

        transform: translateX(5px);
      }

      .active {
        background: rgba(139, 92, 246, 0.25);

        color: #c4b5fd !important;
      }

      #console {
        height: 520px;

        overflow: auto;

        background: rgba(0, 0, 0, 0.45);

        backdrop-filter: blur(15px);

        border-radius: 15px;

        padding: 15px;

        font-family: monospace;
      }

      .log {
        color: #ddd;
      }

      .cmd {
        color: #facc15;
      }

      .sys {
        color: #34d399;
      }

      .err {
        color: #f87171;
      }
    </style>
  </head>

  <body>
    <video class="video-bg" autoplay muted loop playsinline>
      <source src="/wallpaper.mp4" type="video/mp4" />
    </video>

    <div class="overlay"></div>

    <div class="wrapper">
      <aside class="sidebar glass">
        <div class="logo"><%= settings.panelName %></div>

        <div class="menu">
          <a
            href="/server/<%=server.id%>"
            class="<%= currentPage === 'overview' ? 'active' : '' %>"
          >
            <span class="icon home"></span>

            Overview
          </a>

          <a
            href="/server/<%=server.id%>/console"
            class="<%= currentPage === 'console' ? 'active' : '' %>"
          >
            <span class="icon console"></span>

            Console
          </a>

          <a
            href="/server/<%=server.id%>/files"
            class="<%= currentPage === 'files' ? 'active' : '' %>"
          >
            <span class="icon file"></span>

            Files
          </a>

          <a
            href="/server/<%=server.id%>/plugins"
            class="<%= currentPage === 'plugins' ? 'active' : '' %>"
          >
            <span class="icon plugin"></span>

            Plugins
          </a>

          <a
            href="/server/<%=server.id%>/versions"
            class="<%= currentPage === 'version' ? 'active' : '' %>"
          >
            <span class="icon version"></span>

            Version
          </a>

          <a
            href="/server/<%=server.id%>/players"
            class="<%= currentPage === 'players' ? 'active' : '' %>"
          >
            <span class="icon player"></span>

            Players
          </a>

          <a
            href="/server/<%=server.id%>/settings"
            class="<%= currentPage === 'settings' ? 'active' : '' %>"
          >
            <span class="icon setting"></span>

            Settings
          </a>
        </div>

        <div style="margin-top: auto">
          <a href="/dashboard"> ← Back Dashboard </a>
        </div>
      </aside>

      <main class="content">
        <h1 class="text-3xl font-bold mb-5"><%=server.name%> Console</h1>

        <div class="glass p-5 rounded-xl mb-5">
          <div class="grid md:grid-cols-4 gap-4">
            <div>
              CPU

              <h2 id="cpu">0%</h2>
            </div>

            <div>
              RAM

              <h2 id="ram">0%</h2>
            </div>

            <div>
              Disk

              <h2 id="disk">0%</h2>
            </div>

            <div>
              Status

              <h2><%=server.status%></h2>
            </div>
          </div>
        </div>

        <div id="console">
          <% if(logs && logs.length){ %> <% logs.forEach(l=>{ %>

          <div class="log">[DB] <%=l.message%></div>

          <% }) %> <% } %>
        </div>

        <div class="flex gap-3 mt-4">
          <button
            onclick="controlServer('start')"
            class="px-5 py-2 bg-green-500/30 rounded"
          >
            Start
          </button>

          <button
            onclick="controlServer('restart')"
            class="px-5 py-2 bg-yellow-500/30 rounded"
          >
            Restart
          </button>

          <button
            onclick="controlServer('stop')"
            class="px-5 py-2 bg-red-500/30 rounded"
          >
            Stop
          </button>
        </div>

        <form id="commandForm" class="mt-5 flex gap-3">
          <input
            id="command"
            class="flex-1 bg-black/40 p-3 rounded"
            placeholder="Command"
          />

          <button class="px-6 bg-violet-600 rounded">Send</button>
        </form>
      </main>
    </div>

    <script>
      const serverId = "<%=server.id%>";

      const consoleEl = document.getElementById("console");

      function add(msg, type = "log") {
        let d = document.createElement("div");

        d.className = type;

        d.textContent = msg;

        consoleEl.appendChild(d);

        consoleEl.scrollTop = consoleEl.scrollHeight;
      }

      const socket = io();

      socket.on("connect", () => {
        add("[System] Live console connected", "sys");

        socket.emit(
          "join-server",

          serverId
        );
      });

      socket.on("console-output", (data) => {
        if (data.message) add(data.message);
      });

      async function pollLogs() {
        try {
          let r = await fetch(`/server/${serverId}/logs`);

          let j = await r.json();

          if (j.success && j.logs) {
            consoleEl.innerHTML = "";

            j.logs.split("\n").forEach((x) => {
              if (x.trim()) add(x);
            });
          }
        } catch (e) {}
      }

      setInterval(pollLogs, 3000);

      pollLogs();

      document.getElementById("commandForm").onsubmit = async (e) => {
        e.preventDefault();

        let cmd = document.getElementById("command").value;

        if (!cmd) return;

        add("> " + cmd, "cmd");

        await fetch(`/server/${serverId}/command`, {
          method: "POST",

          headers: {
            "Content-Type": "application/json",
          },

          body: JSON.stringify({
            command: cmd,
          }),
        });

        document.getElementById("command").value = "";
      };

      async function controlServer(action) {
        await fetch(`/server/${serverId}/${action}`, {
          method: "POST",

          headers: {
            "Content-Type": "application/json",
          },
        });

        add("[System] " + action + " requested", "sys");
      }

      async function stats() {
        try {
          let r = await fetch(`/server/${serverId}/stats`);

          let j = await r.json();

          if (j) {
            document.getElementById("cpu").innerText = (j.cpu || 0) + "%";

            document.getElementById("ram").innerText = (j.memory || 0) + "%";

            document.getElementById("disk").innerText = (j.disk || 0) + "%";
          }
        } catch (e) {}
      }

      setInterval(stats, 5000);

      stats();
    </script>
  </body>
</html>
