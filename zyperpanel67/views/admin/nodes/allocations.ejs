<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= node.name %> Allocations - <%= settings.panelName %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="icon" href="/falcon.ico" />
</head>
<body class="bg-gray-900 text-white min-h-screen">
  <div class="flex">
    <aside class="w-64 min-h-screen bg-gray-800 border-r border-gray-700 p-4">
      <div class="flex items-center gap-3 mb-8">
        <div
          class="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center"
        >
          <i class="fas fa-server"></i>
        </div>
        <span class="font-bold"><%= settings.panelName %></span>
      </div>
      <nav class="space-y-2">
        <a
          href="/admin/overview"
          class="block px-4 py-2 text-gray-400 hover:bg-gray-700 rounded-lg"
          >Overview</a
        >
        <a
          href="/admin/nodes"
          class="block px-4 py-2 bg-violet-500/20 text-violet-400 rounded-lg"
          >Nodes</a
        >
        <a
          href="/admin/servers"
          class="block px-4 py-2 text-gray-400 hover:bg-gray-700 rounded-lg"
          >Servers</a
        >
        <a
          href="/admin/users"
          class="block px-4 py-2 text-gray-400 hover:bg-gray-700 rounded-lg"
          >Users</a
        >
        <a
          href="/admin/settings"
          class="block px-4 py-2 text-gray-400 hover:bg-gray-700 rounded-lg"
          >Settings</a
        >
      </nav>
    </aside>

    <main class="flex-1 p-8">
      <div class="mb-6">
        <a 
          href="/admin/nodes" 
          class="text-blue-400 hover:text-blue-300 inline-flex items-center gap-2 mb-4"
        >
          <i class="fas fa-arrow-left"></i>
          Back to Nodes
        </a>
        <div class="flex justify-between items-center">
          <div>
            <h1 class="text-3xl font-bold"><%= node.name %> Allocations</h1>
            <p class="text-gray-400 mt-2">Manage IP addresses and ports for this node</p>
          </div>
          <button
            onclick="openCreateModal()"
            class="px-4 py-2 bg-green-500 rounded-lg hover:bg-green-600 flex items-center gap-2"
          >
            <i class="fas fa-plus"></i>
            Add Allocation
          </button>
        </div>
      </div>

      <!-- Allocation Stats -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-gray-800/50 rounded-xl p-4 border border-gray-700/30">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-400">Total Allocations</p>
              <p class="text-2xl font-bold"><%= allocations.length %></p>
            </div>
            <i class="fas fa-network-wired text-blue-400 text-2xl"></i>
          </div>
        </div>
        <div class="bg-gray-800/50 rounded-xl p-4 border border-gray-700/30">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-400">Active Allocations</p>
              <p class="text-2xl font-bold text-green-400">
                <%= allocations.filter(a => a.isActive).length %>
              </p>
            </div>
            <i class="fas fa-check-circle text-green-400 text-2xl"></i>
          </div>
        </div>
        <div class="bg-gray-800/50 rounded-xl p-4 border border-gray-700/30">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-400">Primary IP</p>
              <p class="text-lg font-bold">
                <% const primaryAlloc = allocations.find(a => a.isPrimary); %>
                <%= primaryAlloc ? primaryAlloc.ipAddress : 'Not Set' %>
              </p>
            </div>
            <i class="fas fa-star text-yellow-400 text-2xl"></i>
          </div>
        </div>
        <div class="bg-gray-800/50 rounded-xl p-4 border border-gray-700/30">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-400">Total Ports</p>
              <% 
                let totalPorts = 0;
                allocations.forEach(allocation => {
                  const allPorts = allocation.ports.split(',').reduce((total, range) => {
                    if (range.includes('-')) {
                      const [start, end] = range.split('-').map(p => parseInt(p.trim()));
                      return total + (end - start + 1);
                    }
                    return total + 1;
                  }, 0);
                  totalPorts += allPorts;
                });
              %>
              <p class="text-2xl font-bold"><%= totalPorts %></p>
            </div>
            <i class="fas fa-plug text-purple-400 text-2xl"></i>
          </div>
        </div>
      </div>

      <% if (allocations.length === 0) { %>
      <div class="bg-gray-800/50 rounded-xl border border-gray-700/50 p-12 text-center">
        <i class="fas fa-network-wired text-5xl text-gray-500 mb-4"></i>
        <h3 class="text-xl font-semibold mb-2">No Allocations Yet</h3>
        <p class="text-gray-400 mb-6">Add IP addresses and port ranges to this node</p>
        <button
          onclick="openCreateModal()"
          class="px-6 py-3 bg-green-500 rounded-lg hover:bg-green-600 inline-flex items-center gap-2"
        >
          <i class="fas fa-plus"></i>
          Create First Allocation
        </button>
      </div>
      <% } else { %>
      <div class="bg-gray-800/50 rounded-xl border border-gray-700/50 overflow-hidden mb-8">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-700/30">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">IP Address</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Alias/Domain</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Port Range</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Used Ports</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-300 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700/30">
              <% allocations.forEach(allocation => { 
                const usedPorts = allocation.servers.length;
                const allPorts = allocation.ports.split(',').reduce((total, range) => {
                  if (range.includes('-')) {
                    const [start, end] = range.split('-').map(p => parseInt(p.trim()));
                    return total + (end - start + 1);
                  }
                  return total + 1;
                }, 0);
                const availablePorts = allPorts - usedPorts;
              %>
              <tr class="hover:bg-gray-700/20">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <span class="font-mono"><%= allocation.ipAddress %></span>
                    <% if (allocation.isPrimary) { %>
                    <span class="ml-2 px-2 py-1 text-xs bg-yellow-500/20 text-yellow-400 rounded-full">Primary</span>
                    <% } %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (allocation.alias) { %>
                  <span class="text-blue-300"><%= allocation.alias %></span>
                  <% } else { %>
                  <span class="text-gray-500 italic">None</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="font-mono bg-gray-700/50 px-2 py-1 rounded text-sm"><%= allocation.ports %></span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (allocation.isActive) { %>
                  <span class="px-2 py-1 text-xs bg-green-500/20 text-green-400 rounded-full">Active</span>
                  <% } else { %>
                  <span class="px-2 py-1 text-xs bg-red-500/20 text-red-400 rounded-full">Inactive</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <div class="w-24 bg-gray-700 rounded-full h-2">
                      <div 
                        class="h-full bg-gradient-to-r from-green-500 to-emerald-400 rounded-full"
                        style="width: <%= (usedPorts / allPorts) * 100 %>%"
                      ></div>
                    </div>
                    <span class="text-sm">
                      <%= usedPorts %>/<%= allPorts %>
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex items-center gap-2">
                    <button 
                      onclick="viewPorts('<%= allocation.id %>')"
                      class="px-3 py-1 bg-blue-500/20 text-blue-400 rounded hover:bg-blue-500/30 text-sm flex items-center gap-1"
                    >
                      <i class="fas fa-eye"></i>
                      Ports
                    </button>
                    <button 
                      onclick="openEditModal('<%= allocation.id %>')"
                      class="px-3 py-1 bg-yellow-500/20 text-yellow-400 rounded hover:bg-yellow-500/30 text-sm flex items-center gap-1"
                    >
                      <i class="fas fa-edit"></i>
                      Edit
                    </button>
                    <button 
                      onclick="deleteAllocation('<%= allocation.id %>')"
                      class="px-3 py-1 bg-red-500/20 text-red-400 rounded hover:bg-red-500/30 text-sm flex items-center gap-1"
                    >
                      <i class="fas fa-trash"></i>
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <!-- Port Usage Guide -->
      <div class="bg-gray-800/50 rounded-xl border border-gray-700/50 p-6">
        <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <i class="fas fa-info-circle text-blue-400"></i>
          Allocation Guide
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h4 class="font-medium mb-2 text-gray-300">Port Range Format</h4>
            <ul class="space-y-2 text-sm text-gray-400">
              <li class="flex items-start gap-2">
                <i class="fas fa-check text-green-400 mt-1"></i>
                <span>Single port: <code class="bg-gray-700 px-2 py-1 rounded">25565</code></span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fas fa-check text-green-400 mt-1"></i>
                <span>Port range: <code class="bg-gray-700 px-2 py-1 rounded">25565-25777</code></span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fas fa-check text-green-400 mt-1"></i>
                <span>Multiple ranges: <code class="bg-gray-700 px-2 py-1 rounded">25565-25570,25580-25590</code></span>
              </li>
            </ul>
          </div>
          <div>
            <h4 class="font-medium mb-2 text-gray-300">IP Address Guidelines</h4>
            <ul class="space-y-2 text-sm text-gray-400">
              <li class="flex items-start gap-2">
                <i class="fas fa-server text-blue-400 mt-1"></i>
                <span>Localhost/Development: <code class="bg-gray-700 px-2 py-1 rounded">0.0.0.0</code></span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fas fa-cloud text-purple-400 mt-1"></i>
                <span>Production: Use actual public IPv4 address</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fas fa-globe text-green-400 mt-1"></i>
                <span>Domain/ALIAS: Optional, connects to IPv4</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Create Allocation Modal -->
  <div id="createModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
    <div class="bg-gray-800 rounded-xl p-6 max-w-lg w-full">
      <h3 class="text-xl font-bold mb-4">Create New Allocation</h3>
      <form id="createForm">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-2">IP Address *</label>
            <input
              type="text"
              name="ipAddress"
              required
              placeholder="0.0.0.0 or actual IPv4"
              class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none"
            >
            <p class="text-xs text-gray-400 mt-1">Use 0.0.0.0 for localhost or your server's public IP</p>
          </div>
          
          <div>
            <label class="block text-sm font-medium mb-2">Alias/Domain (Optional)</label>
            <input
              type="text"
              name="alias"
              placeholder="server.yourdomain.com"
              class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none"
            >
            <p class="text-xs text-gray-400 mt-1">Domain that points to your IP address</p>
          </div>
          
          <div>
            <label class="block text-sm font-medium mb-2">Port Range *</label>
            <input
              type="text"
              name="ports"
              required
              placeholder="25565-25777"
              value="25565-25777"
              class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none font-mono"
            >
            <p class="text-xs text-gray-400 mt-1">Format: 25565 or 25565-25777 or 25565,25566,25567</p>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-2">Set as Primary</label>
              <select
                name="isPrimary"
                class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none"
              >
                <option value="no">No</option>
                <option value="yes">Yes</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-2">Status</label>
              <select
                name="isActive"
                class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none"
              >
                <option value="yes">Active</option>
                <option value="no">Inactive</option>
              </select>
            </div>
          </div>
        </div>
        
        <div class="flex justify-end gap-3 mt-6">
          <button
            type="button"
            onclick="closeCreateModal()"
            class="px-4 py-2 bg-gray-700 rounded-lg hover:bg-gray-600"
          >
            Cancel
          </button>
          <button
            type="submit"
            class="px-4 py-2 bg-green-500 rounded-lg hover:bg-green-600"
          >
            Create Allocation
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Allocation Modal -->
  <div id="editModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
    <div class="bg-gray-800 rounded-xl p-6 max-w-lg w-full">
      <h3 class="text-xl font-bold mb-4">Edit Allocation</h3>
      <form id="editForm">
        <input type="hidden" name="allocationId" id="editAllocationId">
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-2">IP Address *</label>
            <input
              type="text"
              name="ipAddress"
              id="editIpAddress"
              required
              class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none"
            >
          </div>
          
          <div>
            <label class="block text-sm font-medium mb-2">Alias/Domain (Optional)</label>
            <input
              type="text"
              name="alias"
              id="editAlias"
              class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none"
            >
          </div>
          
          <div>
            <label class="block text-sm font-medium mb-2">Port Range *</label>
            <input
              type="text"
              name="ports"
              id="editPorts"
              required
              class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none font-mono"
            >
            <p class="text-xs text-yellow-400 mt-1">Warning: Changing ports may affect existing servers</p>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-2">Set as Primary</label>
              <select
                name="isPrimary"
                id="editIsPrimary"
                class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none"
              >
                <option value="no">No</option>
                <option value="yes">Yes</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-2">Status</label>
              <select
                name="isActive"
                id="editIsActive"
                class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg focus:border-blue-500 focus:outline-none"
              >
                <option value="yes">Active</option>
                <option value="no">Inactive</option>
              </select>
            </div>
          </div>
        </div>
        
        <div class="flex justify-end gap-3 mt-6">
          <button
            type="button"
            onclick="closeEditModal()"
            class="px-4 py-2 bg-gray-700 rounded-lg hover:bg-gray-600"
          >
            Cancel
          </button>
          <button
            type="submit"
            class="px-4 py-2 bg-yellow-500 rounded-lg hover:bg-yellow-600"
          >
            Update Allocation
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Ports Modal -->
  <div id="portsModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
    <div class="bg-gray-800 rounded-xl p-6 max-w-2xl w-full max-h-[80vh] overflow-y-auto">
      <h3 class="text-xl font-bold mb-4">Port Usage Details</h3>
      <div id="portsContent" class="space-y-4">
        <!-- Will be populated by JavaScript -->
      </div>
      <div class="flex justify-end mt-6">
        <button
          onclick="closePortsModal()"
          class="px-4 py-2 bg-gray-700 rounded-lg hover:bg-gray-600"
        >
          Close
        </button>
      </div>
    </div>
  </div>

  <script>
    const nodeId = '<%= node.id %>';
    
    function openCreateModal() {
      document.getElementById('createModal').classList.remove('hidden');
    }
    
    function closeCreateModal() {
      document.getElementById('createModal').classList.add('hidden');
      document.getElementById('createForm').reset();
    }
    
    function openEditModal(allocationId) {
      // Find allocation data from table
      const row = document.querySelector(`button[onclick="openEditModal('${allocationId}')"]`).closest('tr');
      const cells = row.querySelectorAll('td');
      
      document.getElementById('editAllocationId').value = allocationId;
      document.getElementById('editIpAddress').value = cells[0].querySelector('.font-mono').textContent.trim();
      document.getElementById('editAlias').value = cells[1].querySelector('span').textContent.trim();
      if (document.getElementById('editAlias').value === 'None') {
        document.getElementById('editAlias').value = '';
      }
      document.getElementById('editPorts').value = cells[2].querySelector('span').textContent.trim();
      
      const isPrimary = cells[0].querySelector('.bg-yellow-500\\/20') !== null;
      document.getElementById('editIsPrimary').value = isPrimary ? 'yes' : 'no';
      
      const isActive = cells[3].querySelector('.bg-green-500\\/20') !== null;
      document.getElementById('editIsActive').value = isActive ? 'yes' : 'no';
      
      document.getElementById('editModal').classList.remove('hidden');
    }
    
    function closeEditModal() {
      document.getElementById('editModal').classList.add('hidden');
    }
    
    async function viewPorts(allocationId) {
      try {
        const response = await fetch(`/admin/nodes/allocations/${allocationId}/ports`);
        const data = await response.json();
        
        if (data.success) {
          const portsContent = document.getElementById('portsContent');
          portsContent.innerHTML = `
            <div class="bg-gray-700/30 rounded-lg p-4 mb-4">
              <h4 class="font-semibold mb-2">Allocation Details</h4>
              <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                  <span class="text-gray-400">IP Address:</span>
                  <span class="font-mono ml-2">${data.allocation.ipAddress}</span>
                </div>
                <div>
                  <span class="text-gray-400">Alias:</span>
                  <span class="ml-2">${data.allocation.alias || 'None'}</span>
                </div>
                <div>
                  <span class="text-gray-400">Port Range:</span>
                  <span class="font-mono ml-2">${data.allocation.ports}</span>
                </div>
                <div>
                  <span class="text-gray-400">Total Ports:</span>
                  <span class="ml-2">${data.ports.all.length}</span>
                </div>
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-gray-700/30 rounded-lg p-4">
                <h4 class="font-semibold mb-2 text-green-400">Available Ports (${data.ports.available.length})</h4>
                <div class="flex flex-wrap gap-2">
                  ${data.ports.available.map(port => `
                    <span class="px-2 py-1 bg-green-500/20 text-green-400 rounded text-sm font-mono">
                      ${port}
                    </span>
                  `).join('')}
                </div>
              </div>
              
              <div class="bg-gray-700/30 rounded-lg p-4">
                <h4 class="font-semibold mb-2 text-red-400">Used Ports (${data.ports.used.length})</h4>
                ${data.ports.usedDetails.length > 0 ? `
                  <div class="space-y-2">
                    ${data.ports.usedDetails.map(detail => `
                      <div class="flex items-center justify-between">
                        <span class="font-mono">${detail.port}</span>
                        <a href="/server/${detail.server.id}" class="text-blue-400 hover:text-blue-300 text-sm">
                          ${detail.server.name}
                        </a>
                      </div>
                    `).join('')}
                  </div>
                ` : '<p class="text-gray-400 text-sm">No ports in use</p>'}
              </div>
            </div>
          `;
          
          document.getElementById('portsModal').classList.remove('hidden');
        } else {
          Swal.fire({
            title: 'Error!',
            text: data.error,
            icon: 'error',
            confirmButtonText: 'OK',
            background: '#1f2937',
            color: '#fff'
          });
        }
      } catch (error) {
        Swal.fire({
          title: 'Error!',
          text: error.message,
          icon: 'error',
          confirmButtonText: 'OK',
          background: '#1f2937',
          color: '#fff'
        });
      }
    }
    
    function closePortsModal() {
      document.getElementById('portsModal').classList.add('hidden');
    }
    
    async function deleteAllocation(allocationId) {
      const result = await Swal.fire({
        title: 'Are you sure?',
        text: "This will delete the allocation. Make sure no servers are using it!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, delete it!',
        cancelButtonText: 'Cancel',
        confirmButtonColor: '#ef4444',
        background: '#1f2937',
        color: '#fff'
      });
      
      if (result.isConfirmed) {
        try {
          const response = await fetch(`/admin/nodes/allocations/${allocationId}/delete`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            }
          });
          
          const data = await response.json();
          
          if (data.success) {
            Swal.fire({
